# ============================================================
# Zeta IMA — Environment Variables
# Copy to .env and fill in all values before running.
# Never commit .env to source control.
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Microsoft Bot (Teams bot identity) ─────────────────────
MICROSOFT_APP_ID=<bot-app-id-from-azure-bot-service>
MICROSOFT_APP_PASSWORD=<bot-client-secret>

# ── Azure AD (Graph API + Key Vault auth) ──────────────────
AZ_TENANT_ID=<your-azure-tenant-id>
AZ_CLIENT_ID=<same-as-MICROSOFT_APP_ID>
AZ_CLIENT_SECRET=<same-as-MICROSOFT_APP_PASSWORD>

# ── Azure Key Vault (stores Fernet vault key) ───────────────
# Generate vault name in Azure portal — must be globally unique
AZ_KEY_VAULT_URL=https://<your-vault-name>.vault.azure.net
AZ_KEY_VAULT_SECRET_NAME=zeta-vault-key

# ── Redis (session checkpointer) ────────────────────────────
REDIS_URL=redis://localhost:6379
SESSION_TTL_HOURS=48

# ── Qdrant (vector store) ───────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=brand_voice
QDRANT_KB_COLLECTION=knowledge_base
BRAND_CONTEXT_TOP_K=5
KB_CONTEXT_TOP_K=5

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://zeta:zeta_dev@localhost:5432/zeta_ima

# ── LLM model selection ─────────────────────────────────────
LLM_COPY=gpt-4o
LLM_REVIEW=gpt-4o-mini
LLM_ROUTER=gpt-4o-mini

# ── Teams broadcast channel ─────────────────────────────────
# Channel where approved outputs are auto-posted.
# Right-click the channel in Teams → Get link to channel → copy ID from URL.
TEAMS_TEAM_ID=<team-object-id>
TEAMS_BROADCAST_CHANNEL_ID=19:xxxx@thread.tacv2

# ── JWT (web app auth, Teams SSO) ───────────────────────────
# Use a long random string in production: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-me-in-prod

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
