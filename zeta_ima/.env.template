# ============================================================
# Zeta IMA — Environment Variables
# Copy to .env and fill in values before running
# ============================================================

# --- LLM ---
OPENAI_API_KEY=sk-...
LLM_COPY=gpt-4o
LLM_REVIEW=gpt-4o-mini

# --- Redis (session checkpointer) ---
# Default: docker compose redis service
REDIS_URL=redis://localhost:6379
SESSION_TTL_HOURS=48

# --- Qdrant (brand memory) ---
# Default: docker compose qdrant service (no auth)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=brand_voice
BRAND_CONTEXT_TOP_K=5

# --- PostgreSQL (campaigns, audit log) ---
# Default: docker compose postgres service
DATABASE_URL=postgresql://zeta:zeta_dev@localhost:5432/zeta_ima

# --- Microsoft Teams Bot ---
# Get these from Azure Portal > Azure Bot > Configuration
# See README for registration steps
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
